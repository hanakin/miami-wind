{
	"$schema": "https://ui.shadcn.com/schema/registry.json",
	"name": "miami-wind",
	"homepage": "https://github.com/hanakin/miami-wind",
	"items": [
		{
			"name": "conventions",
			"type": "registry:item",
			"title": "Miami Wind conventions",
			"description": "Agent, coding, and design standards. Companions are thin pointers to AGENTS.md.",
			"files": [
				{
					"path": "conventions/AGENTS.md",
					"type": "registry:file",
					"target": "~/AGENTS.md"
				},
				{
					"path": "conventions/CODING-STANDARDS.md",
					"type": "registry:file",
					"target": "~/CODING-STANDARDS.md"
				},
				{
					"path": "conventions/DESIGN.md",
					"type": "registry:file",
					"target": "~/DESIGN.md"
				},
				{
					"path": "conventions/CLAUDE.md",
					"type": "registry:file",
					"target": "~/CLAUDE.md"
				},
				{
					"path": "conventions/GEMINI.md",
					"type": "registry:file",
					"target": "~/GEMINI.md"
				},
				{
					"path": "conventions/AGENT.md",
					"type": "registry:file",
					"target": "~/AGENT.md"
				},
				{
					"path": "conventions/copilot-instructions.md",
					"type": "registry:file",
					"target": "~/.github/copilot-instructions.md"
				}
			]
		},
		{
			"name": "theme",
			"type": "registry:item",
			"title": "Miami Wind theme",
			"description": "Dark-only Miami Wind theme. @theme layer: greyscale (grey-50..grey-1300), code-named grey semantics, MW color-name aliases of native Tailwind accents, status + interactive semantics. dark layer: shadcn global fallbacks (background, foreground, border=white/7, ring=transparent, radius).",
			"cssVars": {
				"theme": {
					"--color-grey-50": "#cdd6f4",
					"--color-grey-100": "#bac2de",
					"--color-grey-200": "#a6adc8",
					"--color-grey-300": "#9399b2",
					"--color-grey-400": "#7f849c",
					"--color-grey-500": "#6c7086",
					"--color-grey-600": "#585b70",
					"--color-grey-700": "#45475a",
					"--color-grey-800": "#313244",
					"--color-grey-900": "#1e1e2e",
					"--color-grey-1000": "#181825",
					"--color-grey-1100": "#11111b",
					"--color-grey-1200": "#0d0d14",
					"--color-grey-1300": "#09090b",
					"--color-crust": "var(--color-grey-1300)",
					"--color-mantle": "var(--color-grey-1200)",
					"--color-base": "var(--color-grey-1100)",
					"--color-surface": "var(--color-grey-1000)",
					"--color-text": "var(--color-grey-50)",
					"--color-subtext": "var(--color-grey-100)",
					"--color-subtext0": "var(--color-grey-200)",
					"--color-pink": "var(--color-pink-300)",
					"--color-bright-pink": "var(--color-pink-500)",
					"--color-cyan": "var(--color-cyan-400)",
					"--color-bright-cyan": "var(--color-sky-400)",
					"--color-yellow": "var(--color-yellow-200)",
					"--color-bright-yellow": "var(--color-yellow-300)",
					"--color-purple": "var(--color-purple-400)",
					"--color-bright-purple": "var(--color-violet-400)",
					"--color-blue": "var(--color-indigo-400)",
					"--color-bright-blue": "var(--color-blue-600)",
					"--color-green": "var(--color-emerald-400)",
					"--color-bright-green": "var(--color-green-400)",
					"--color-red": "var(--color-red-400)",
					"--color-bright-red": "var(--color-rose-500)",
					"--color-orange": "var(--color-orange-300)",
					"--color-bright-orange": "var(--color-orange-400)",
					"--color-success": "var(--color-bright-green)",
					"--color-success-foreground": "var(--color-base)",
					"--color-warn": "var(--color-bright-yellow)",
					"--color-warn-foreground": "var(--color-base)",
					"--color-error": "var(--color-bright-red)",
					"--color-error-foreground": "var(--color-base)",
					"--color-info": "var(--color-bright-blue)",
					"--color-info-foreground": "var(--color-base)",
					"--color-interactive": "var(--color-grey-800)",
					"--color-primary": "var(--color-pink)",
					"--color-secondary": "var(--color-cyan)",
					"--color-pink-transparent": "color-mix(in oklab, var(--color-pink) 50%, transparent)",
					"--color-cyan-transparent": "color-mix(in oklab, var(--color-cyan) 50%, transparent)",
					"--color-primary-transparent": "var(--color-pink-transparent)",
					"--color-secondary-transparent": "var(--color-cyan-transparent)"
				},
				"dark": {
					"--background": "var(--color-crust)",
					"--foreground": "var(--color-text)",
					"--border": "color-mix(in oklab, var(--color-white) 7%, transparent)",
					"--ring": "transparent",
					"--radius": "0.375rem",
					"--input": "var(--color-interactive)",
					"--popover": "var(--color-surface)",
					"--card": "var(--color-base)",
					"--sidebar": "var(--color-mantle)",
					"--accent": "var(--color-interactive)",
					"--accent-foreground": "var(--color-pink)",
					"--sidebar-foreground": "var(--foreground)",
					"--sidebar-primary": "var(--primary)",
					"--sidebar-primary-foreground": "var(--primary-foreground)",
					"--sidebar-accent": "var(--accent)",
					"--sidebar-accent-foreground": "var(--accent-foreground)",
					"--sidebar-border": "var(--border)",
					"--sidebar-ring": "var(--ring)",
					"--secondary": "var(--color-secondary)",
					"--secondary-foreground": "var(--color-base)",
					"--primary": "var(--color-primary)",
					"--primary-foreground": "var(--color-text)",
					"--destructive": "var(--color-error)",
					"--destructive-foreground": "var(--color-error-foreground)",
					"--card-foreground": "var(--color-text)",
					"--popover-foreground": "var(--color-text)",
					"--muted-foreground": "var(--color-grey-700)",
					"--muted": "var(--color-grey-500)"
				}
			}
		},
		{
			"name": "mw-cva",
			"type": "registry:file",
			"title": "mw-cva plugin",
			"description": "Build-time Vite plugin. Links a vanilla shadcn primitive to its separate Miami Wind cva (components/ui/cva/<name>.ts) by filename convention, with inline fallback when no cva file exists. Required for the cva layer to work. Imported in vite.config.ts.",
			"files": [
				{
					"path": "plugin/mw-cva.ts",
					"type": "registry:file",
					"target": "~/mw-cva.ts"
				}
			]
		},
		{
			"name": "icon",
			"type": "registry:ui",
			"title": "Icon",
			"description": "Icon renderer. Discriminated union: type 'iconify' (string name like 'mdi:add') or 'custom' (an SVG component). 20px default size. No baked default set — 'prefer mdi' is agent guidance, not code.",
			"dependencies": [
				"@iconify/react"
			],
			"files": [
				{
					"path": "registry/components/ui/icon.tsx",
					"type": "registry:ui"
				}
			]
		},
		{
			"name": "button",
			"type": "registry:file",
			"title": "Button variants (cva)",
			"description": "Miami Wind button variants. The shadcn button component is vanilla (from shadcn's own registry); this ships only the cva layer. Pink primary, cyan secondary, error destructive; pointer cursor, visible hover/active, no ring.",
			"registryDependencies": [
				"theme",
				"mw-cva"
			],
			"dependencies": [
				"class-variance-authority"
			],
			"files": [
				{
					"path": "registry/components/ui/cva/button.ts",
					"type": "registry:file",
					"target": "~/components/ui/cva/button.ts"
				}
			]
		},
		{
			"name": "registry",
			"type": "registry:item",
			"title": "Miami Wind (all)",
			"description": "Aggregate: installs the whole Miami Wind set — conventions, theme, mw-cva, utils, and every primitive. This is what the scaffolder's bin runs.",
			"registryDependencies": [
				"conventions",
				"theme",
				"mw-cva",
				"icon",
				"button"
			]
		}
	]
}
