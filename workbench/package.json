{
	"name": "@miami-wind/workbench",
	"private": true,
	"type": "module",
	"description": "Miami Wind Workbench — author and manage the registry's cvas, custom primitives, and theme with live preview.",
	"scripts": {
		"dev": "concurrently -k -n web,api -c cyan,magenta \"vite\" \"bun --watch server/index.ts\"",
		"dev:web": "vite",
		"dev:api": "bun --watch server/index.ts",
		"build": "vite build",
		"start": "bun server/index.ts",
		"routes": "tsr generate",
		"check": "tsr generate && biome check . && bun run typecheck && bun run test",
		"fmt": "biome check --write .",
		"lint": "biome lint .",
		"typecheck": "tsc --noEmit",
		"test": "vitest run",
		"test:watch": "vitest",
		"test:ui": "vitest --ui"
	},
	"dependencies": {
		"@base-ui/react": "^1.6.0",
		"@hono/zod-validator": "^0.8.0",
		"@hookform/resolvers": "^5.4.0",
		"@iconify/react": "^6.0.2",
		"@tanstack/react-query": "^5.101.2",
		"@tanstack/react-router": "^1.170.16",
		"class-variance-authority": "^0.7.1",
		"clsx": "^2.1.1",
		"cmdk": "^1.1.1",
		"date-fns": "^4.4.0",
		"embla-carousel-react": "^8.6.0",
		"hono": "^4.12.27",
		"input-otp": "^1.4.2",
		"lucide-react": "^1.22.0",
		"next-themes": "^0.4.6",
		"radix-ui": "^1.6.0",
		"react": "^19.2.7",
		"react-colorful": "^5.7.0",
		"react-day-picker": "^10.0.1",
		"react-dom": "^19.2.7",
		"react-hook-form": "^7.80.0",
		"react-resizable-panels": "^4",
		"recharts": "3.8.0",
		"sonner": "^2.0.7",
		"sugar-high": "^1.2.1",
		"tailwind-merge": "^3.6.0",
		"vaul": "^1.1.2",
		"zod": "^4.4.3",
		"zustand": "^5.0.14"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.5.1",
		"@tailwindcss/node": "^4.3.1",
		"@tailwindcss/vite": "^4.3.1",
		"@tanstack/router-cli": "^1.167.17",
		"@tanstack/router-plugin": "^1.168.18",
		"@testing-library/dom": "^10.4.1",
		"@testing-library/react": "^16.3.2",
		"@types/bun": "^1.3.14",
		"@types/node": "^26.0.1",
		"@types/react": "^19.2.17",
		"@types/react-dom": "^19.2.3",
		"@vitejs/plugin-react": "^6.0.3",
		"concurrently": "^10.0.3",
		"jsdom": "^29.1.1",
		"tailwindcss": "^4.3.1",
		"typescript": "^6.0.3",
		"vite": "^8.1.0",
		"vitest": "^4.1.9"
	}
}
